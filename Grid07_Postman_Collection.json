{
  "info": {
    "_postman_id": "grid07-api-collection",
    "name": "Grid07 Backend API",
    "description": "Complete API collection for Grid07 Spring Boot assignment.\n\nBase URL: http://localhost:8080\n\nSetup:\n1. docker-compose up postgres redis -d\n2. mvn spring-boot:run\n3. Run 'Seed - Create User' and 'Seed - Create Bot' first\n4. Copy returned IDs into subsequent requests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",  "value": "http://localhost:8080", "type": "string" },
    { "key": "postId",   "value": "1",                     "type": "string" },
    { "key": "userId",   "value": "1",                     "type": "string" },
    { "key": "botId",    "value": "1",                     "type": "string" },
    { "key": "commentId","value": "1",                     "type": "string" }
  ],
  "item": [

    {
      "name": "Phase 1 — Core API",
      "item": [

        {
          "name": "Create Post (Human)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/posts", "host": ["{{baseUrl}}"], "path": ["api","posts"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"authorId\": {{userId}},\n  \"authorType\": \"USER\",\n  \"content\": \"Hello world! This is my first post.\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                "const json = pm.response.json();",
                "pm.test('Post has ID', () => pm.expect(json.data.id).to.be.a('number'));",
                "pm.collectionVariables.set('postId', json.data.id);"
              ]
            }
          }]
        },

        {
          "name": "Create Post (Bot)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/posts", "host": ["{{baseUrl}}"], "path": ["api","posts"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"authorId\": {{botId}},\n  \"authorType\": \"BOT\",\n  \"content\": \"Automated post generated by AlphaBot.\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status is 201', () => pm.response.to.have.status(201));"] }
          }]
        },

        {
          "name": "Get Post (with virality score)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/posts/{{postId}}", "host": ["{{baseUrl}}"], "path": ["api","posts","{{postId}}"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Has virality score', () => pm.expect(pm.response.json().data.viralityScore).to.be.a('number'));"
            ]}
          }]
        },

        {
          "name": "Add Comment (Human — top level)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/posts/{{postId}}/comments", "host": ["{{baseUrl}}"], "path": ["api","posts","{{postId}}","comments"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"authorId\": {{userId}},\n  \"authorType\": \"USER\",\n  \"content\": \"Great post! Really enjoyed reading it.\",\n  \"parentCommentId\": null\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status is 201', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "pm.test('Depth is 1', () => pm.expect(json.data.depthLevel).to.equal(1));",
              "pm.collectionVariables.set('commentId', json.data.id);"
            ]}
          }]
        },

        {
          "name": "Add Comment (Bot — triggers guardrails)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/posts/{{postId}}/comments", "host": ["{{baseUrl}}"], "path": ["api","posts","{{postId}}","comments"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"authorId\": {{botId}},\n  \"authorType\": \"BOT\",\n  \"content\": \"I am a bot and I find this post interesting!\",\n  \"parentCommentId\": null\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status is 201 or 429', () => {",
              "  pm.expect(pm.response.code).to.be.oneOf([201, 429]);",
              "});"
            ]}
          }]
        },

        {
          "name": "Add Nested Comment (depth 2)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/posts/{{postId}}/comments", "host": ["{{baseUrl}}"], "path": ["api","posts","{{postId}}","comments"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"authorId\": {{userId}},\n  \"authorType\": \"USER\",\n  \"content\": \"Replying to parent comment at depth 2.\",\n  \"parentCommentId\": {{commentId}}\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status is 201', () => pm.response.to.have.status(201));",
              "pm.test('Depth is 2', () => pm.expect(pm.response.json().data.depthLevel).to.equal(2));"
            ]}
          }]
        },

        {
          "name": "Like Post (Human)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/posts/{{postId}}/like", "host": ["{{baseUrl}}"], "path": ["api","posts","{{postId}}","like"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": {{userId}}\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Virality >= 20', () => pm.expect(pm.response.json().data.viralityScore).to.be.at.least(20));"
            ]}
          }]
        },

        {
          "name": "Like Post (Duplicate — expect 409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/posts/{{postId}}/like", "host": ["{{baseUrl}}"], "path": ["api","posts","{{postId}}","like"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": {{userId}}\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status is 409 Conflict', () => pm.response.to.have.status(409));"] }
          }]
        }

      ]
    },

    {
      "name": "Phase 2 — Guardrail Edge Cases",
      "item": [

        {
          "name": "Bot Comment — Cooldown Block (expect 429)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/posts/{{postId}}/comments", "host": ["{{baseUrl}}"], "path": ["api","posts","{{postId}}","comments"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"authorId\": {{botId}},\n  \"authorType\": \"BOT\",\n  \"content\": \"Second comment from same bot — should be blocked.\",\n  \"parentCommentId\": null\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status is 429 (cooldown)', () => pm.response.to.have.status(429));"] }
          }]
        },

        {
          "name": "Post Not Found (expect 404)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/posts/999999", "host": ["{{baseUrl}}"], "path": ["api","posts","999999"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status is 404', () => pm.response.to.have.status(404));"] }
          }]
        },

        {
          "name": "Invalid Author Type (expect 400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/posts", "host": ["{{baseUrl}}"], "path": ["api","posts"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"authorId\": 1,\n  \"authorType\": \"ALIEN\",\n  \"content\": \"Invalid type test\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status is 400', () => pm.response.to.have.status(400));"] }
          }]
        },

        {
          "name": "Missing Required Field (expect 400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/posts", "host": ["{{baseUrl}}"], "path": ["api","posts"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"authorId\": 1,\n  \"authorType\": \"USER\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status is 400', () => pm.response.to.have.status(400));"] }
          }]
        }

      ]
    }

  ]
}
